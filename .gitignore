.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Host-side unit test binaries (see scripts/run_host_tests.sh)
.tmp-host-tests/

# Python / local tooling
.venv/
.venv*/
.venv_easyeda2kicad/
venv/
__pycache__/
*.py[cod]

# macOS
.DS_Store

# KiCad — versioned backups are zipped under *-backups/; no need in git
*-backups/
fp-info-cache
kicad/easyeda2kicad_parts/_import_*/

# KiCad — session / autosave / lock (never commit)
**/\#auto_saved_files#
~*.lck

# KiCad — duplicate PCB export next to .kicad_pcb (regenerate from project)
*.kicad_pcb.zip

# KiCad — symbol backup when editing from disk
*.bak

# Fab house exports (gerbers, drill, BOM, positions — regenerate from KiCad)
**/_pcbway_export_review/

# Scratch / one-off extracts (not source of truth)
docs/.bno08x_datasheet_extract.txt

# WiFi / OpenTrack host (copy from include/secrets.h.example)
include/secrets.h

# Web flasher — built by CI (GitHub Pages) or locally; do not commit
web-flasher/firmware/**/*.bin

# Optional: reference-only downloads (uncomment if you do not want these tracked)
# kicad/_reference/
